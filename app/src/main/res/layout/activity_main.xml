<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#070707">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="4dp"
        android:background="#0E0E0E">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FOUNTAIN HOME"
            android:textColor="#BB86FC"
            android:textSize="18sp"
            android:letterSpacing="0.12"
            android:textStyle="bold"/>

        <ImageButton android:id="@+id/search_btn"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_search"
            android:background="?attr/selectableItemBackground"
            android:tint="#DDDDDD" android:contentDescription="Search"/>

        <ImageButton android:id="@+id/library_btn"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_agenda"
            android:background="?attr/selectableItemBackground"
            android:tint="#DDDDDD" android:contentDescription="Library"/>

        <ImageButton android:id="@+id/settings_btn"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="?attr/selectableItemBackground"
            android:tint="#DDDDDD" android:contentDescription="Settings"/>
    </LinearLayout>

    <!-- Search bar (hidden by default) -->
    <SearchView android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:queryHint="Search movies, TV shows..."
        android:iconifiedByDefault="false"
        android:background="#1A1A1A"
        android:visibility="gone"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HERO BANNER -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="240dp">

                <ImageView android:id="@+id/featured_banner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#1A1A1A"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_hero"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:id="@+id/featured_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:shadowColor="#000"
                        android:shadowRadius="6"/>

                    <TextView android:id="@+id/featured_meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>

                    <Button android:id="@+id/featured_play_btn"
                        android:layout_width="140dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="10dp"
                        android:text="▶  PLAY NOW"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:backgroundTint="#BB86FC"/>
                </LinearLayout>
            </FrameLayout>

            <!-- Popular Movies -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="20dp" android:paddingBottom="8dp"
                android:gravity="center_vertical">
                <View android:layout_width="4dp" android:layout_height="16dp"
                    android:background="#BB86FC" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Popular Movies"
                    android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/popular_movies_rv"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingHorizontal="8dp" android:nestedScrollingEnabled="false"/>

            <!-- Popular TV -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="20dp" android:paddingBottom="8dp"
                android:gravity="center_vertical">
                <View android:layout_width="4dp" android:layout_height="16dp"
                    android:background="#03DAC6" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Popular TV Shows"
                    android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/popular_tv_rv"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingHorizontal="8dp" android:nestedScrollingEnabled="false"/>

            <!-- Top Rated -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="20dp" android:paddingBottom="8dp"
                android:gravity="center_vertical">
                <View android:layout_width="4dp" android:layout_height="16dp"
                    android:background="#FFD600" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Top Rated"
                    android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/top_rated_rv"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingHorizontal="8dp" android:nestedScrollingEnabled="false"/>

            <!-- Now Playing -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="20dp" android:paddingBottom="8dp"
                android:gravity="center_vertical">
                <View android:layout_width="4dp" android:layout_height="16dp"
                    android:background="#CF6679" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Now Playing"
                    android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/now_playing_rv"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingHorizontal="8dp" android:paddingBottom="24dp"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
